APP_NAME=XMS Hotel Management
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

DATABASE_URL=postgresql+asyncpg://postgres:password@your-db-host:5432/xms_db
DATABASE_URL_SYNC=postgresql://postgres:password@your-db-host:5432/xms_db

PORT=8001

JWT_SECRET_KEY=change-this-to-a-random-secret-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=["*"]
