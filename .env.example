APP_NAME=XMS Hotel Management
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/xms_db
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/xms_db

JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

REDIS_URL=redis://localhost:6379/0

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@xms.com

CORS_ORIGINS=["*"]
